# backend 전용 .env 템플릿 — Prisma + backend dev 서버가 자동 로드.
# 사용: copy .env.example .env (Windows) 또는 cp .env.example .env (Linux/macOS)
# 시크릿 값은 절대 커밋하지 않는다 (CLAUDE.md §보안).

NODE_ENV=development
PORT=3000

# Prisma datasource — dev SQLite (운영 시 PostgreSQL URL로 교체)
DATABASE_URL=file:./conduit.db

# JWT — 32바이트 이상 랜덤. openssl rand -base64 32 또는
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Maximum 256}))
JWT_SECRET=CHANGE_ME_TO_32_BYTE_RANDOM
JWT_EXP_SECONDS=86400
BCRYPT_COST=12

CORS_ALLOW_ORIGINS=http://localhost:5173
MAX_PAGE_LIMIT=100
LOG_LEVEL=debug

# RealWorld Conduit — 환경변수 예시 (시크릿 값은 절대 커밋하지 않는다, CLAUDE.md §보안)
# 사용: cp .env.example .env  → JWT_SECRET 등 실제 값 채움
#
# 12-scaffolding/typescript.md §6 환경변수 표 미러.

# === Backend ===
NODE_ENV=development                              # development | test | production
PORT=3000                                         # Express listen

# 데이터베이스: dev=SQLite / prod=PostgreSQL 양방 지원 (Prisma datasource)
# dev SQLite:
DATABASE_URL=file:./conduit.db
# prod PostgreSQL (Docker Compose db 서비스):
# DATABASE_URL=postgresql://conduit:CHANGE_ME@db:5432/conduit

# JWT — 절대 본 값을 사용하지 말 것. openssl rand -base64 32 등으로 32바이트+ 랜덤 생성
JWT_SECRET=CHANGE_ME_TO_32_BYTE_RANDOM
JWT_EXP_SECONDS=86400                             # 24h (R-N-02)
BCRYPT_COST=12                                    # R-N-02

CORS_ALLOW_ORIGINS=http://localhost:5173          # 쉼표 구분 화이트리스트
MAX_PAGE_LIMIT=100                                # R-F-06
LOG_LEVEL=debug                                   # info(prod) / debug(dev)

# === Frontend (VITE_ prefix만 브라우저 노출) ===
VITE_API_BASE=/api                                # dev에서 Vite proxy로 :3000 전달
VITE_TOKEN_STORAGE_KEY=conduit.jwt
